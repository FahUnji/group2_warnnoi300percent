# Copy to .env and fill in real values. Never commit .env to git.

# Database — SQLite file path (default: backend/jira.db, created automatically)
# DB_PATH=backend/jira.db

# Encryption — generate once with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Atlassian OAuth 2.0 (required for login)
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_REDIRECT_URI=http://localhost:8000/api/auth/atlassian/callback

# Frontend URL (used for OAuth redirects)
FRONTEND_URL=http://localhost:3000

# Session cookie — set to true in production (HTTPS only)
COOKIE_SECURE=false
