# Atlassian OAuth 2.0 credentials
# Create an app at: https://developer.atlassian.com/console/myapps/
ATLASSIAN_CLIENT_ID=your_client_id_here
ATLASSIAN_CLIENT_SECRET=your_client_secret_here

# Must match the callback URL registered in your Atlassian app
REDIRECT_URI=http://localhost:3000/auth/callback

# Where to send the user after successful login
APP_URL=http://localhost:3000/UI/login.html

PORT=3000
